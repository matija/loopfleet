{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "loopfleet",
  "version": "0.1.0",
  "identifier": "com.loopfleet.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "cwd": "../frontend",
      "script": "npm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "../frontend",
      "script": "npm run build"
    }
  },
  "app": {
    "windows": [
      {
        "title": "loopfleet",
        "width": 1200,
        "height": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
